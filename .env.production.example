NEXT_PUBLIC_SITE_URL=https://nguyenhuynhkhanh.com
NEXT_PUBLIC_ENABLE_SUPABASE=true

# Supabase self-hosted API gateway URL, thường là https://api.nguyenhuynhkhanh.com
NEXT_PUBLIC_SUPABASE_URL=https://api.nguyenhuynhkhanh.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_with_self_hosted_anon_key

# Server-only secrets
SUPABASE_SERVICE_ROLE_KEY=replace_with_self_hosted_service_role_key
SUPABASE_JWT_SECRET=replace_with_self_hosted_jwt_secret

# Email
RESEND_API_KEY=re_your_key
RESEND_FROM_EMAIL="MIDIGI <hello@nguyenhuynhkhanh.com>"
ADMIN_NOTIFICATION_EMAIL=admin@nguyenhuynhkhanh.com

# Security
CSRF_SECRET=replace_with_32_plus_random_characters
WEBHOOK_SIGNING_SECRET=replace_with_32_plus_random_characters
NEXT_RUNTIME_LOG_LEVEL=info
