NEXT_PUBLIC_SITE_URL=http://localhost:3002
NEXT_PUBLIC_ENABLE_SUPABASE=false
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_public_anon_key

SUPABASE_SERVICE_ROLE_KEY=your_server_only_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret
SUPABASE_PROJECT_ID=your-project-id

RESEND_API_KEY=re_your_key
RESEND_FROM_EMAIL="MIDIGI <hello@midigi.vn>"
ADMIN_NOTIFICATION_EMAIL=admin@midigi.vn

CSRF_SECRET=replace_with_a_32_byte_random_string
WEBHOOK_SIGNING_SECRET=replace_with_random_webhook_secret
NEXT_RUNTIME_LOG_LEVEL=info
