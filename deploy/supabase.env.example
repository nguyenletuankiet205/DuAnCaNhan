############
# Secrets
############
POSTGRES_PASSWORD=replace_with_strong_postgres_password
JWT_SECRET=replace_with_at_least_32_chars_jwt_secret
ANON_KEY=replace_with_generated_anon_key
SERVICE_ROLE_KEY=replace_with_generated_service_role_key
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=replace_with_strong_studio_password
SECRET_KEY_BASE=replace_with_at_least_64_chars_secret
VAULT_ENC_KEY=replace_with_32_chars_encryption_key

############
# API
############
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
SUPABASE_PUBLIC_URL=https://api.nguyenhuynhkhanh.com
API_EXTERNAL_URL=https://api.nguyenhuynhkhanh.com

############
# Site URLs
############
SITE_URL=https://nguyenhuynhkhanh.com
ADDITIONAL_REDIRECT_URLS=https://nguyenhuynhkhanh.com/auth/callback,http://localhost:3000/auth/callback

############
# Email Auth
############
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
SMTP_ADMIN_EMAIL=admin@nguyenhuynhkhanh.com
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=replace_with_resend_api_key
SMTP_SENDER_NAME=MIDIGI

############
# Studio
############
STUDIO_DEFAULT_ORGANIZATION=MIDIGI
STUDIO_DEFAULT_PROJECT=MIDIGI Marketing Platform
STUDIO_PORT=3000
SUPABASE_REST_URL=http://kong:8000
SUPABASE_URL=http://kong:8000

############
# Storage
############
STORAGE_BACKEND=file
FILE_SIZE_LIMIT=10485760

############
# Logs
############
LOGFLARE_PUBLIC_ACCESS_TOKEN=replace_with_logflare_public_token
LOGFLARE_PRIVATE_ACCESS_TOKEN=replace_with_logflare_private_token
DOCKER_SOCKET_LOCATION=/var/run/docker.sock
